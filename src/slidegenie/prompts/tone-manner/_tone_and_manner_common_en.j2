visual_identity:
    style: A highly professional, calm, and minimalist enterprise design inspired by top-tier global consulting firms. Emphasize credibility, clarity, and logical structure.
    background: Pure white.
    decorations: Minimal. Use sharp-edged rectangular shapes (no rounded corners). No gradients, shadows, or 3D effects.

color_palette:
    primary_color: "#6D6358"  # Taupe / Earth Brown (emphasis, markers)
    accent_color: "#D9D0C1"   # Light Beige (headers, box backgrounds)
    background_color: "#FFFFFF"
    text_main_color: "#333333"
    text_header_color: "#000000"
    text_lead_color: "#000000"

layout_geometry:
    header:
        height_ratio: Approximately 15–20% of the slide height
        elements: Place the slide title in bold text at the top-left. Use text only; no decorative ribbons or shapes.
    lead_message:
        presence: mandatory
        position: Directly below the slide title, at the top of the main content area
        description:
            - This area contains the key conclusion or executive summary of the slide in complete sentences (1–2 lines).
            - Do not use bullet labels or section titles; express it as a clear message.
            - Do NOT use highlighting, underlines, partial color changes, or background emphasis.
    margin:
        Use standard business document margins.
        Ensure a bottom margin equivalent to approximately 8% of the slide height.
        Maintain high information density while keeping a clean grid-based layout.

typography:
    font_family_feel: "{{default_font_name}}", a neutral and modern font suitable for professional business documents.
    header_style:
        font: "{{default_font_name}}"
        weight: Bold
        size: Large (approx. 20–24pt)
        align: Left
    lead_style:
        font: "{{default_font_name}}"
        weight: Bold or Regular
        size: Medium-Large (approx. 16–18pt)
        color: text_lead_color
        align: Left
    body_style:
        font: "{{default_font_name}}"
        weight: Regular
        size: Medium (approx. 10–12pt)
        line_spacing: Adequate spacing to ensure readability.

graphics:
    image_style:
        Photographs are rarely used.
        If used, place them as plain rectangles with no decorative effects.
        Diagrams such as chevrons or process flows must be flat design only.
    icon_style:
        Simple, flat icons.
        Single color only: black or the primary brand color (#6D6358).
    charts:
        Limit the color palette.
        Use only Primary Color (#6D6358) and Accent Color (#D9D0C1) with tonal variations.
        Do NOT use strong colors such as navy or pure black.
    slide_background_color: Must be white.

